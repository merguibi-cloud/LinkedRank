# Application
APP_URL=http://localhost:3000

# Vercel Cron — secret pour sécuriser /api/cron/* (Vercel l'envoie en Bearer automatiquement)
CRON_SECRET=

# Production Vercel Elite Society
# APP_URL=https://linkedrank-pi.vercel.app
# VITE_APP_URL=https://linkedrank-pi.vercel.app
# LINKEDIN_REDIRECT_URI=https://linkedrank-pi.vercel.app/api/linkedin/callback
VITE_APP_URL=http://localhost:3000
JWT_SECRET=

# Base de données Supabase (Postgres)
# App runtime — pooler transaction (port 6543) :
# Dashboard → Database → Connection string → URI → mode Transaction
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres
# Migrations / drizzle-kit — connexion directe (port 5432) :
DATABASE_DIRECT_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# LinkedIn — ajouter LINKEDIN_REDIRECT_URI dans Authorized redirect URLs sur linkedin.com/developers
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:3000/api/linkedin/callback

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
VITE_STRIPE_PUBLISHABLE_KEY=

# IA — Gemini (prioritaire) ou OpenAI
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
# gpt-image-1 (qualité) ou dall-e-3 (plus rapide, recommandé si timeouts)
OPENAI_IMAGE_MODEL=dall-e-3

# Supabase Auth (dashboard : Project Settings → API)
SUPABASE_URL=
SUPABASE_ANON_KEY=
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
