# Application
APP_URL=http://localhost:3000
VITE_APP_URL=http://localhost:3000
JWT_SECRET=

# Base de données Supabase (Postgres)
# Dashboard Supabase → Project Settings → Database → Connection string
# DATABASE_URL = pooler TRANSACTION (port 6543) — utilisé par l'app au runtime (prepare:false requis, voir server/_core/database.ts)
# DATABASE_DIRECT_URL = pooler SESSION (port 5432) — utilisé pour les migrations drizzle-kit (DDL non fiable en mode transaction)
# Remplacez [YOUR-PASSWORD] par le mot de passe de la base
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
DATABASE_DIRECT_URL=postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres

# LinkedIn — ajouter LINKEDIN_REDIRECT_URI dans Authorized redirect URLs sur linkedin.com/developers
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:3000/api/linkedin/callback
# Version API REST LinkedIn (format YYYYMM, ex. 202606)
LINKEDIN_API_VERSION=202606

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
VITE_STRIPE_PUBLISHABLE_KEY=

# IA — Gemini (prioritaire) ou OpenAI
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# Nano Banana — génération d'images native Gemini (gemini-2.5-flash-image ou gemini-3.1-flash-image)
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
# gemini (Nano Banana) ou openai — auto: gemini si GEMINI_API_KEY est défini
IMAGE_PROVIDER=gemini
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
# gpt-image-1 (qualité) ou dall-e-3 (plus rapide, recommandé si timeouts)
OPENAI_IMAGE_MODEL=dall-e-3

# Supabase Auth + Storage (dashboard : Project Settings → API)
SUPABASE_URL=
SUPABASE_ANON_KEY=
# service_role — requis pour upload images en production (Vercel)
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=media
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
